<view class="page">
  <view class="page-halo page-halo-top"></view>
  <view class="page-halo page-halo-bottom"></view>

  <view class="panel panel-industry">
    <view class="panel-head">
      <view>
        <view class="panel-title">选择行业</view>
      </view>
    </view>

    <view class="industry-toolbar {{industryExpanded ? 'industry-toolbar-expanded' : ''}}">
      <view class="industry-collapsed-shell">
        <view class="industry-list industry-list-collapsed">
          <block wx:for="{{collapsedIndustryOptions}}" wx:key="*this">
            <view
              class="industry-tag {{selectedIndustry === item ? 'industry-tag-active' : ''}}"
              data-industry="{{item}}"
              bindtap="onIndustryChange"
            >
              {{item}}
            </view>
          </block>
        </view>
        <view class="industry-fade"></view>
      </view>

      <view wx:if="{{industryExpanded}}" class="industry-list industry-list-expanded">
        <block wx:for="{{expandedIndustryOptions}}" wx:key="*this">
          <view
            class="industry-tag {{selectedIndustry === item ? 'industry-tag-active' : ''}}"
            data-industry="{{item}}"
            bindtap="onIndustryChange"
          >
            {{item}}
          </view>
        </block>
      </view>

      <view class="industry-toggle {{industryExpanded ? 'industry-toggle-active' : ''}}" bindtap="toggleIndustryExpand">
        <text class="industry-toggle-icon {{industryExpanded ? 'industry-toggle-icon-expanded' : ''}}">⌄</text>
      </view>
    </view>
  </view>

  <view class="panel panel-input">
    <view class="panel-head">
      <view>
        <view class="panel-title">请输入要翻译的内容</view>
      </view>
      <text class="panel-link" bindtap="handleClearInput">Clear</text>
    </view>

    <view class="editor-shell {{inputText ? 'editor-shell-filled' : ''}}">
      <textarea
        class="editor-textarea"
        auto-height
        maxlength="-1"
        placeholder="中英文皆可，AI自动识别语言并翻译为另一种语言"
        placeholder-class="editor-placeholder"
        value="{{inputText}}"
        bindinput="onInputChange"
      ></textarea>
    </view>
  </view>

  <view class="panel panel-output panel-output-active">
    <view class="panel-head">
      <view>
        <view class="panel-title">翻译结果</view>
      </view>
      <text class="panel-link" bindtap="handleCopyResult">Copy</text>
    </view>

    <view class="result-shell {{(resultText || resultPending || resultError) ? 'result-shell-filled' : ''}}">
      <view class="result-content {{resultError ? 'result-content-error' : (resultText ? 'result-content-filled' : 'result-content-empty') }}">
        <text class="result-text">{{resultText || resultError || (loading ? 'Translating...' : '')}}</text>
      </view>
    </view>
  </view>
</view>
