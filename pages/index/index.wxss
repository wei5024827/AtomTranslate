page {
  --bg: #f5f5f7;
  --surface: rgba(255, 255, 255, 0.78);
  --surface-strong: #ffffff;
  --line: rgba(15, 23, 42, 0.08);
  --line-strong: rgba(15, 23, 42, 0.14);
  --text-primary: #111111;
  --text-secondary: rgba(17, 17, 17, 0.62);
  --text-tertiary: rgba(17, 17, 17, 0.34);
  --shadow-soft: 0 20rpx 60rpx rgba(15, 23, 42, 0.06);
  --shadow-card: 0 14rpx 40rpx rgba(15, 23, 42, 0.05);
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0) 34%),
    linear-gradient(180deg, #fbfbfd 0%, var(--bg) 100%);
}

.page {
  position: relative;
  min-height: 100vh;
  padding: 40rpx 28rpx 36rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.page-halo {
  position: absolute;
  border-radius: 999rpx;
  pointer-events: none;
  filter: blur(10rpx);
  opacity: 0.8;
}

.page-halo-top {
  top: -120rpx;
  right: -120rpx;
  width: 380rpx;
  height: 380rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.95) 0%, rgba(235, 235, 240, 0) 72%);
}

.page-halo-bottom {
  left: -160rpx;
  bottom: 140rpx;
  width: 360rpx;
  height: 360rpx;
  background: radial-gradient(circle, rgba(238, 238, 243, 0.9) 0%, rgba(238, 238, 243, 0) 74%);
}

.panel {
  position: relative;
  z-index: 1;
}

.panel-head,
.panel-actions {
  display: flex;
  align-items: center;
}

.panel-head {
  justify-content: space-between;
}

.panel {
  margin-top: 16rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.88);
  border-radius: 32rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.82) 0%, rgba(255, 255, 255, 0.68) 100%);
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(24rpx);
}

.panel-output {
  min-height: 300rpx;
}

.panel-title {
  color: var(--text-primary);
  font-size: 31rpx;
  font-weight: 600;
  letter-spacing: -0.4rpx;
}

.panel-count,
.panel-action {
  color: var(--text-secondary);
  font-size: 22rpx;
}

.panel-link {
  transition: opacity 180ms ease, transform 180ms ease;
}

.panel-link:active {
  opacity: 0.58;
  transform: scale(0.98);
}

.editor-shell,
.result-shell {
  margin-top: 20rpx;
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
  transition: border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
}

.editor-shell {
  min-height: 168rpx;
}

.result-shell {
  min-height: 120rpx;
  padding: 28rpx;
}

.editor-shell-filled,
.result-shell-filled {
  border-color: var(--line-strong);
}

.editor-shell:focus-within {
  transform: translateY(-2rpx);
  border-color: var(--line-strong);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.72),
    0 0 0 8rpx rgba(17, 17, 17, 0.03);
}

.editor-textarea,
.result-content {
  width: 100%;
  box-sizing: border-box;
  font-size: 31rpx;
  line-height: 1.8;
}

.editor-textarea {
  color: var(--text-primary);
  min-height: 112rpx;
  max-height: 336rpx;
}

.editor-placeholder,
.result-content-empty {
  color: var(--text-tertiary);
}

.panel-link {
  color: var(--text-secondary);
  font-size: 24rpx;
}

.panel-output-active {
  animation: settleIn 320ms ease both;
}

.result-content {
  color: var(--text-primary);
  min-height: 0;
  word-break: break-word;
  white-space: pre-wrap;
}

.result-text {
  display: block;
  width: 100%;
}

.result-content-error {
  color: #b42318;
}

.result-content-filled {
  animation: fadeSoft 240ms ease both;
}

@keyframes fadeSoft {
  from {
    opacity: 0;
    transform: translateY(8rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes settleIn {
  0% {
    transform: translateY(8rpx);
  }

  100% {
    transform: translateY(0);
  }
}
