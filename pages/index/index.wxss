page {
  --bg-start: #f6f8fc;
  --bg-end: #eef2ff;
  --text-primary: #222222;
  --text-secondary: #667085;
  --text-tertiary: #98a2b3;
  --line-soft: rgba(148, 163, 184, 0.18);
  --line-strong: rgba(99, 102, 241, 0.32);
  --card-bg: rgba(255, 255, 255, 0.9);
  --card-shadow: 0 16rpx 48rpx rgba(15, 23, 42, 0.08);
  --panel-radius: 36rpx;
  --field-radius: 28rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, var(--bg-start) 0%, var(--bg-end) 100%);
}

.page {
  position: relative;
  min-height: 100vh;
  padding: 56rpx 48rpx 48rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  overflow: hidden;
}

.bg-orb {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(12rpx);
  opacity: 0.7;
  pointer-events: none;
}

.bg-orb-top {
  top: -80rpx;
  right: -40rpx;
  width: 320rpx;
  height: 320rpx;
  background: radial-gradient(circle, rgba(108, 99, 255, 0.16) 0%, rgba(108, 99, 255, 0) 72%);
}

.bg-orb-bottom {
  left: -120rpx;
  bottom: 160rpx;
  width: 360rpx;
  height: 360rpx;
  background: radial-gradient(circle, rgba(79, 140, 255, 0.14) 0%, rgba(79, 140, 255, 0) 74%);
}

.hero,
.panel,
.translate-btn {
  position: relative;
  z-index: 1;
  animation: fadeSlideUp 300ms ease both;
}

.hero {
  padding-top: 8rpx;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  height: 44rpx;
  padding: 0 18rpx;
  border: 1rpx solid rgba(99, 102, 241, 0.16);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.56);
  color: #5463ff;
  font-size: 22rpx;
  letter-spacing: 0.6rpx;
  backdrop-filter: blur(12rpx);
}

.hero-title {
  margin-top: 18rpx;
  color: var(--text-primary);
  font-size: 44rpx;
  line-height: 1.2;
  font-weight: 600;
  letter-spacing: -0.6rpx;
}

.hero-subtitle {
  margin-top: 12rpx;
  max-width: 640rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.7;
}

.panel {
  padding: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border-radius: var(--panel-radius);
  background: var(--card-bg);
  box-shadow: var(--card-shadow);
  backdrop-filter: blur(18rpx);
}

.panel-input {
  animation-delay: 40ms;
}

.panel-output {
  flex: 1;
  min-height: 340rpx;
  animation-delay: 140ms;
}

.panel-output-active {
  animation: fadeInSoft 240ms ease both;
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.panel-title {
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 600;
}

.panel-meta,
.copy-text {
  color: var(--text-secondary);
  font-size: 24rpx;
}

.copy-text {
  min-width: 88rpx;
  min-height: 44rpx;
  text-align: right;
}

.field-shell {
  border: 2rpx solid var(--line-soft);
  border-radius: var(--field-radius);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(248, 250, 252, 0.92) 100%);
  transition: border-color 150ms ease, box-shadow 150ms ease, transform 150ms ease;
}

.field-shell:focus-within {
  border-color: var(--line-strong);
  box-shadow: 0 0 0 10rpx rgba(79, 140, 255, 0.08);
  transform: translateY(-2rpx);
}

.input-box,
.output-box {
  width: 100%;
  min-height: 320rpx;
  box-sizing: border-box;
  border-radius: var(--field-radius);
  font-size: 32rpx;
  line-height: 1.75;
}

.input-box {
  padding: 28rpx;
  color: #101828;
}

.input-placeholder {
  color: var(--text-tertiary);
}

.translate-btn {
  height: 96rpx;
  padding: 0;
  border: none;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #4f8cff 0%, #6c63ff 100%);
  box-shadow: 0 18rpx 36rpx rgba(92, 111, 255, 0.26);
  animation-delay: 90ms;
  transition: transform 150ms ease, box-shadow 150ms ease, opacity 150ms ease;
}

.translate-btn::after {
  border: none;
}

.translate-btn-hover {
  transform: scale(0.96);
  box-shadow: 0 10rpx 22rpx rgba(92, 111, 255, 0.2);
}

.translate-btn[disabled] {
  opacity: 0.88;
}

.translate-btn-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.translate-spinner {
  width: 28rpx;
  height: 28rpx;
  margin-right: 14rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.35);
  border-top-color: #ffffff;
  border-radius: 50%;
  box-sizing: border-box;
  animation: spin 700ms linear infinite;
}

.translate-btn-label {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 0.4rpx;
}

.output-box {
  padding: 28rpx;
  border: 2rpx solid rgba(148, 163, 184, 0.16);
  background: linear-gradient(180deg, rgba(250, 251, 255, 0.96) 0%, rgba(244, 247, 255, 0.92) 100%);
  color: #111827;
  word-break: break-word;
  white-space: pre-wrap;
  transition: opacity 220ms ease, transform 220ms ease, border-color 220ms ease;
}

.output-placeholder {
  color: var(--text-tertiary);
}

.output-filled {
  border-color: rgba(79, 140, 255, 0.18);
  animation: fadeInSoft 260ms ease both;
}

@keyframes fadeSlideUp {
  from {
    opacity: 0;
    transform: translateY(18rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInSoft {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
